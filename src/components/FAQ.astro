---
const faqItems = [
  {
    question: "What kind of content does Sedrax publish?",
    answer: "We publish practical Android guides, app comparisons, safety tips, customization ideas, and privacy explainers for everyday users."
  },
  {
    question: "Are the guides safe to follow?",
    answer: "Every guide includes safety checks, permission explanations, and warnings about common risks. We always recommend downloading apps from official or verified sources."
  },
  {
    question: "How can I contact the Sedrax team?",
    answer: "You can reach us via email at support@modapksoft.com or through the contact page. We typically respond within 24–48 hours."
  },
  {
    question: "Do I need to root my device?",
    answer: "Most of our guides do not require root access. When a guide mentions advanced methods, we clearly label them and explain the risks."
  },
  {
    question: "Can I suggest an app or topic?",
    answer: "Absolutely. We welcome reader suggestions. Send your ideas to support@modapksoft.com and our editorial team will review them."
  },
  {
    question: "Is Sedrax free to use?",
    answer: "Yes, all guides and articles on Sedrax are free to read. We may include affiliate links, but editorial recommendations remain independent."
  }
];

// Randomize and select 4 FAQs
const shuffledFAQs = faqItems.sort(() => Math.random() - 0.5);
const selectedFAQs = shuffledFAQs.slice(0, 4);
---

<section class="faq-section" aria-labelledby="faq-heading">
  <div class="container">
    <header class="section-header">
      <span class="eyebrow">FAQ</span>
      <h2 id="faq-heading">Questions? We've got answers.</h2>
      <p>Everything you need to know about using Sedrax.</p>
    </header>

    <div class="faq-grid">
      {selectedFAQs.map(item => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 6rem 2rem;
    background: var(--color-white);
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3.5rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-indigo-600);
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-slate-900);
    line-height: 1.2;
  }

  .section-header p {
    font-size: 1.125rem;
    color: var(--color-slate-600);
    line-height: 1.7;
  }

  .faq-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: var(--color-slate-50);
    border-radius: 0.875rem;
    padding: 1.5rem;
    border: 1px solid var(--color-slate-100);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .faq-item[open] {
    background: var(--color-white);
    border-color: var(--color-indigo-100);
  }

  .faq-item summary {
    font-weight: 700;
    cursor: pointer;
    list-style: none;
    color: var(--color-slate-900);
    font-size: 1.0625rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: var(--color-indigo-100);
    color: var(--color-indigo-700);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.125rem;
  }

  .faq-item[open] summary::after {
    content: "−";
    background: var(--color-indigo-600);
    color: var(--color-white);
  }

  .faq-item p {
    margin-top: 1rem;
    color: var(--color-slate-600);
    line-height: 1.8;
  }

  @media (max-width: 640px) {
    .faq-section {
      padding: 4rem 1.5rem;
    }

    h2 {
      font-size: 2rem;
    }
  }
</style>
